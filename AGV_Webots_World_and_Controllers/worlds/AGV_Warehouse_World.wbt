  orientation -0.4679594043244729 0.48745071956657327 0.7371606282882411 1.8319190859751369
  position -1.6515538028794525 -41.29937351086555 87.91412271117235
}
TexturedBackground {
}
TexturedBackgroundLight {
}
Floor {
    size 69 22
    appearance DEF DROPOFF_LOOK Appearance {
        material Material {
            diffuseColor 0.5 0.5 0.5
        }
    }
}

### Robots ###
# Pioneer 3-DX controller unit 1
