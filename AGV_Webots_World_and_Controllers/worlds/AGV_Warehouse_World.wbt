  translation 2 0 0.0975
  name "PIONEER_3_2"
}

# Sole owner of human and forklift movement.
DEF DYNAMIC_ENVIRONMENT_SUPERVISOR Robot {
  supervisor TRUE
  name "DYNAMIC_ENVIRONMENT_SUPERVISOR"
  controller "DynamicEnvironmentSupervisor"
}

